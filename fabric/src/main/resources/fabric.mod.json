{
  "schemaVersion": 1,
  "id": "jcraft",
  "version": "${version}",
  "name": "Jcraft",
  "description": "so yeah i wanted to add jojo stands to mc",
  "authors": [
    "Arna",
    "MrSterner",
    "PlanetTeamSpeak"
  ],
  "contact": {
    "homepage": "https://fabricmc.net/",
    "sources": "https://github.com/Arna577/jcraft-eoe/"
  },
  "license": "CC0-1.0",
  "icon": "assets/jcraft/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "net.arna.jcraft.fabric.JCraftFabric"
    ],
    "client": [
      "net.arna.jcraft.fabric.client.JCraftFabricClient"
    ],
    "cardinal-components": [
      "net.arna.jcraft.fabric.common.component.JComponents"
    ]
  },
  "accessWidener" : "jcraft.accesswidener",
  "mixins": [
    "jcraft.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.11",
    "minecraft": "~1.20.1",
    "java": ">=17",
    "architectury": ">=9.2.14",
    "fabric-api": "*",
    "player-animator": ">=0.3",
    "cardinal-components-base": "*",
    "cardinal-components-entity": "*",
    "cardinal-components-world": "*"
  },
  "custom": {
    "cardinal-components": [
      "jcraft:gravity_direction",
      "jcraft:stand",
      "jcraft:spec",
      "jcraft:ph",
      "jcraft:cooldowns",
      "jcraft:time_stop",
      "jcraft:misc",
      "jcraft:bomb_tracker",
      "jcraft:grab",
      "jcraft:hit_property",
      "jcraft:shockwave_handler",
      "jcraft:gravity_shift",
      "jcraft:vampire"
    ]
  }
}
